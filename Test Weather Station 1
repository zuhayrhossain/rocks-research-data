int count = 0;

//HumdTemp
#include <DHT11.h>
DHT11 dht11(8);

//Temp
const int temp_pin = A1;

//Phot
const int phot_pin = A14;
int photValue;
int photValueNormal;

//UV
const int uv_pin = A15;
int uvValue;
int uvValueNormal;

//Therm0
#include <OneWire.h>
#include <DallasTemperature.h>

OneWire therm0(5);
DallasTemperature sensor0(&therm0);
const int therm0_pin = 5;
int therm0Value;
int therm0ValueAdjusted;

//Therm1
OneWire therm1(4);
DallasTemperature sensor1(&therm1);
const int therm1_pin = 4;
int therm1Value;
int therm1ValueAdjusted;

//Therm2
OneWire therm2(3);
DallasTemperature sensor2(&therm2);
const int therm2_pin = 3;
int therm2Value;
int therm2ValueAdjusted;


void setup() {

Serial.begin(9600);

//Phot 
pinMode(phot_pin, INPUT);

//therms
sensor0.begin();
sensor1.begin();
sensor2.begin();
}

void loop() {
count++;
Serial.println("---------------------------");
Serial.print("Count_Number: ");
Serial.println(count);
HumdTemp();
Temp();
Phot();
UV();
Therm0();
Therm1();
Therm2();
delay(30000);
}

void HumdTemp() {
  int temperature = 0;
    int humidity = 0;

    // Attempt to read the temperature and humidity values from the DHT11 sensor.
    int result = dht11.readTemperatureHumidity(temperature, humidity);

    // Check the results of the readings.
    // If the reading is successful, print the temperature and humidity values.
    // If there are errors, print the appropriate error messages.
    if (result == 0) {
        Serial.print("Temperature: ");
        Serial.print(temperature);
        Serial.println(" °C");
        Serial.print("Humidity: ");
        Serial.print(humidity);
        Serial.println(" %");
    } else {
        // Print error message based on the error code.
        Serial.println(DHT11::getErrorString(result));}
}

void Temp() {
  int temp_adc_val;
  float temp_val;
  temp_adc_val = analogRead(temp_pin);	/* Read Temperature */
  temp_val = (temp_adc_val * 4.88);	/* Convert adc value to equivalent voltage */
  temp_val = (temp_val/10);	/* LM35 gives output of 10mv/°C */
  Serial.print("Temperature: ");
  Serial.print(temp_val);
  Serial.println(" °C");
}

void Phot(){
  photValue = analogRead(phot_pin);
  photValueNormal = (photValue/10);
  Serial.print("Light_Value: ");
  Serial.print(photValueNormal);
  Serial.println(" %");
}

void UV() {
  uvValue = analogRead(uv_pin);
  uvValueNormal = (uvValue/10);
  Serial.print("UV_Value: ");
  Serial.print(uvValue);
  Serial.println("");
}

void Therm0() {
  sensor0.requestTemperatures();

  Serial.print("Therm_0: ");
  Serial.print(sensor0.getTempCByIndex(0));
  Serial.println(" °C");
}

void Therm1() {
  sensor1.requestTemperatures();

  Serial.print("Therm_1: ");
  Serial.print(sensor1.getTempCByIndex(0));
  Serial.println(" °C");
}

void Therm2() {
  sensor2.requestTemperatures();

  Serial.print("Therm_2: ");
  Serial.print(sensor2.getTempCByIndex(0));
  Serial.println(" °C");
}